# OpenRouter API Key for AI Digital Twin
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model and comma-separated fallback chain (OpenRouter route=fallback)
LLM_PRIMARY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
LLM_OPENROUTER_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,openai/gpt-oss-120b:free

# Digital Twin question quotas (0 = unlimited for that window)
DIGITAL_TWIN_MAX_QUESTIONS_PER_VISIT=5
DIGITAL_TWIN_MAX_QUESTIONS_PER_DAY=20

# Optional: cap conversation history sent to model (token savings)
DIGITAL_TWIN_MAX_HISTORY_TURNS=6

# Optional: HMAC secret for signed quota cookies (defaults to OPENROUTER_API_KEY)
# DIGITAL_TWIN_QUOTA_SECRET=your_quota_signing_secret

# Chatbase embed — leave empty to use OpenRouter only
# NEXT_PUBLIC_CHATBASE_EMBED_ID=

# Provider control: auto | chatbase | openrouter
NEXT_PUBLIC_DIGITAL_TWIN_FORCE_PROVIDER=openrouter

# Optional: proactive switch threshold for mirror counter (best-effort per browser)
DIGITAL_TWIN_CHATBASE_MONTHLY_BUDGET=50

# Microsoft Clarity Analytics (optional)
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Profile photo (defaults to /profile-photo.jpg in public/)
# NEXT_PUBLIC_PROFILE_IMAGE_URL=/profile-photo.jpg

# Local CV assets under public/cv/
NEXT_PUBLIC_CV_URL=/cv/kashif-jilani-cv.docx
NEXT_PUBLIC_RESUME_TEXT_URL=http://localhost:3000/cv/kashif-fullstack-cv.md

# Sanity CMS — leave empty until configured (routes /blogs and /studio remain)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# SANITY_API_TOKEN=
